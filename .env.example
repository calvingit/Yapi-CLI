
# YApi Cookie拆分配置（推荐）
_yapi_token=
_yapi_uid=

# 兼容写法：完整Cookie（二选一）
# YAPI_TOKEN=_yapi_token=xxxxx; _yapi_uid=1234; other_cookie=xxx

# 项目基础URL
YAPI_BASE_URL=http://dapi.meiyunji.net

# 缓存时效(分钟)，默认10分钟(6小时)
YAPI_CACHE_TTL=10

# 日志级别: debug, info, warn, error, none
# - debug: 输出所有日志，包括详细的调试信息
# - info: 输出信息、警告和错误日志(默认)
# - warn: 只输出警告和错误日志
# - error: 只输出错误日志
# - none: 不输出任何日志
YAPI_LOG_LEVEL=info